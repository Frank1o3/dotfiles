[global]
monitor = 0
follow = keyboard
width = (320, 500)
height = (120, 500)
origin = top-right
offset = (17x17)
scale = 0
gap_size = 8
indicate_hidden = yes
frame_width = 0
corner_radius = 12
padding = 16
horizontal_padding = 16
font = "SF Mono 9, JetBrains Mono 9, Noto Sans 9, monospace"
line_height = 2
alignment = left
icon_position = left
stack_duplicates = true
hide_duplicate_count = false
icon_path = /usr/share/icons/Papirus-Dark/48x48/apps:/usr/share/icons/Papirus-Dark/48x48/status
max_icon_size = 64
markup = full
format = "<b>%a</b>\n%s\n%b"
progress_bar = true
progress_bar_height = 6
progress_bar_corner_radius = 3
progress_bar_frame_width = 1
separator_height = 1
ignore_dbusclose = false
mouse_left_click = close_current
mouse_middle_click = do_action
mouse_right_click = close_all

frame_color = "{{color4}}"
highlight = "{{color5}}"
separator_color = "{{foreground}}"

[experimental]
per_monitor_dpi = true

[urgency_low]
timeout = 3
background = "{{background | darken(0.1)}}ee"
foreground = "{{foreground}}"
frame_color = "{{color4}}"

[urgency_normal]
timeout = 5
background = "{{background | darken(0.1)}}80"
foreground = "{{foreground}}"
frame_color = "{{color6}}"

[urgency_critical]
timeout = 10
background = "{{background | darken(0.1)}}ee"
foreground = "{{foreground}}"
frame_color = "{{color9}}"
